{
  "permissions": {
    "allow": [
      "WebFetch(domain:psgc.gitlab.io)",
      "WebFetch(domain:ph-locations-api.buonzz.com)",
      "PowerShell(try { $r = Invoke-WebRequest -Uri \"https://psgc.cloud/api/v2/regions\" -TimeoutSec 15 -UseBasicParsing; \"STATUS: $\\($r.StatusCode\\)\"; $r.Content.Substring\\(0,200\\) } catch { \"ERROR: $\\($_.Exception.Message\\)\" })"
    ]
  }
}
